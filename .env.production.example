# Propa3 MVP internal production — copy to .env on EC2

NODE_ENV=production

# MySQL (dedicated app user — see docs/DEPLOY.md)
DATABASE_URL="mysql://propa3:CHANGE_ME@localhost:3306/prop_a3"

# API
API_PORT=4000
API_URL=https://propa3.com

# Web — baked in at `npm run build`; change requires rebuild
NEXT_PUBLIC_API_URL=https://propa3.com

# CORS — comma-separated origins
WEB_URL=https://propa3.com,https://www.propa3.com

# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND

# CI/CD — GitHub Actions POST /api/deploy/hook (header X-Deploy-Secret)
# Generate: openssl rand -hex 32
DEPLOY_HOOK_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX32

# Optional — repo root on EC2 (default: two levels up from apps/api)
# APP_ROOT=/var/www/propa3

# Optional S3 when uploads exceed ~5 GB (Phase 2)
# AWS_REGION=af-south-1
# AWS_S3_BUCKET=propa3-uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
