# Propa3 staging / production — copy to .env on EC2

NODE_ENV=production

# MySQL (create user + DB on EC2 — see docs/DEPLOY.md)
DATABASE_URL="mysql://propa3:CHANGE_ME@localhost:3306/prop_a3"

# API
API_PORT=4000
API_URL=https://propa3.com

# Web — must match public URL (used at build time for NEXT_PUBLIC_*)
NEXT_PUBLIC_API_URL=https://propa3.com

# CORS — comma-separated if multiple origins
WEB_URL=https://propa3.com,https://www.propa3.com

# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND

# Optional S3 (production uploads — leave empty to use local uploads/)
# AWS_REGION=af-south-1
# AWS_S3_BUCKET=propa3-uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
